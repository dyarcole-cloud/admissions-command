# Demo mode bypasses the /app auth gate. Disable for production.
NEXT_PUBLIC_DEMO_MODE=true

# AWS Lambda /invoke wrapper for Bedrock-backed AI advisor + DEID-on-submit.
# When unset, /api/invoke falls back to a deterministic mock for advisor.coach.
LAMBDA_INVOKE_URL=https://your-aws-region.amazonaws.com/invoke
LAMBDA_INVOKE_TOKEN=
